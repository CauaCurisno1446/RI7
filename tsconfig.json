{
  "compilerOptions": {
    "target": "ES2015",
    "module": "NodeNext",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "out",
    "rootDir": "src",
    "noImplicitAny": false
  },
  "include": [
    "src/**/*"
  ]
}